PORT=3000
DB_PATH=./amtracked.db
# Set to "true" to log all intercepted XHR URLs during scraping (useful for endpoint discovery)
DEBUG_XHR=false

# Paste the cookie string from a DevTools cURL copy here to enable direct API requests
# without launching a browser. Get it from: amtrak.com search → DevTools Network →
# journey-solution-option → right-click → Copy as cURL → grab the -b '...' value.
# Cookies last ~8-10 minutes. Leave blank to use Playwright (slower, sometimes blocked).
AMTRAK_COOKIES=
