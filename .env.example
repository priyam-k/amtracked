PORT=3000
DB_PATH=./amtracked.db
# How often the scheduler checks active alerts (minutes). Default: 60.
POLL_INTERVAL_MINUTES=60
# Set to "true" to log all intercepted XHR URLs during scraping (useful for endpoint discovery)
DEBUG_XHR=false

# Session cookies for direct API requests (no browser needed). Cookies last ~8-10 min.
# Get them: amtrak.com → do any search → DevTools Network → journey-solution-option →
# right-click → "Copy as cURL".
#
# Easiest: paste the entire cURL command (multiline, unmodified) into .amtrak-curl
# in the project root. That file is gitignored — no escaping needed.
#
# Alternatively, set AMTRAK_COOKIES to just the cookie string (the -b '...' value).
# Leave blank to fall back to Playwright automation.
AMTRAK_COOKIES=
