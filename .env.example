PORT=3000
DB_PATH=./amtracked.db
# Set to "true" to log all intercepted XHR URLs during scraping (useful for endpoint discovery)
DEBUG_XHR=false

# Session cookies for direct API requests (no browser needed). Cookies last ~8-10 min.
# Get them: amtrak.com → do any search → DevTools Network → journey-solution-option →
# right-click → "Copy as cURL" → paste the ENTIRE command into AMTRAK_CURL.
# Alternatively, paste just the cookie string (the -b '...' value) into AMTRAK_COOKIES.
# Leave both blank to fall back to Playwright automation.
AMTRAK_CURL=
AMTRAK_COOKIES=
